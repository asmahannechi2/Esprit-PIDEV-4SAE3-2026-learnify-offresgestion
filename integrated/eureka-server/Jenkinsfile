pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "eureka-server"
        DOCKER_TAG = "latest"
        DOCKERHUB_REPO = "wiwi2003/eureka-server"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Artifact') {
            steps {
                dir('integrated/eureka-server') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('integrated/eureka-server') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }

        // 🔴 AJOUT IMPORTANT
        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh """
                    docker login -u $USER -p $PASS
                    docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKERHUB_REPO}:${DOCKER_TAG}
                    docker push ${DOCKERHUB_REPO}:${DOCKER_TAG}
                    """
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    // Créer le namespace s'il n'existe pas
                    sh "kubectl create namespace pidev || true"
                    
                    // Appliquer les secrets
                    sh "kubectl apply -f kubernetes/secrets.yaml"
                    
                    // Déployer Eureka Server
                    sh "kubectl apply -f kubernetes/eureka-server.yaml"
                    
                    // Attendre que le déploiement soit prêt
                    sh "kubectl rollout status deployment/eureka-server -n pidev --timeout=5m"
                    
                    echo "✅ Eureka Server deployed to Kubernetes successfully"
                    echo "🌐 Access Eureka Dashboard at: http://NODE_IP:30761"
                }
            }
        }
    }
}