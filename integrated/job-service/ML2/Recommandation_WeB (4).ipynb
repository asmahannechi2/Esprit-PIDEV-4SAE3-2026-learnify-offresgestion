# === UPLOAD dans une carte moderne ===
st.markdown("""
<div class='upload-card'>
<h4 style='color:#1976d2;margin-bottom:10px;'>📤 Importez vos fichiers</h4>
</div>
""", unsafe_allow_html=True)
col1, col2 = st.columns(2)
with col1:
    offres_file = st.file_uploader("📂 Charger le fichier des Offres d'emploi", type="csv", key="offres")
with col2:
    cv_file = st.file_uploader("📂 Charger le fichier des CV utilisateurs", type="csv", key="cv")

if offres_file and cv_file:
    try:
        offres = pd.read_csv(offres_file)
        cv_users = pd.read_csv(cv_file)

        # Vérification des colonnes requises
        offres_cols = {'titre', 'competences', 'localisation', 'type_contrat', 'salaire'}
        cv_cols = {'nom', 'competences_cv'}
        if not offres_cols.issubset(offres.columns):
            st.error(f"Le fichier des offres doit contenir les colonnes : {offres_cols}")
            st.stop()
        if not cv_cols.issubset(cv_users.columns):
            st.error(f"Le fichier des CV doit contenir les colonnes : {cv_cols}")
            st.stop()

        # Nettoyage des doublons et colonnes inutiles
        offres.drop_duplicates(inplace=True)
        cv_users.drop_duplicates(inplace=True)
        offres.dropna(thresh=int(0.5 * offres.shape[1]), inplace=True)
        cv_users.dropna(thresh=int(0.5 * cv_users.shape[1]), inplace=True)
        offres.fillna('', inplace=True)
        cv_users.fillna('', inplace=True)
        offres.columns = offres.columns.map(str)
        cv_users.columns = cv_users.columns.map(str)
        offres = offres.loc[:, ~offres.columns.str.contains('^Unnamed')]
        cv_users = cv_users.loc[:, ~cv_users.columns.str.contains('^Unnamed')]


        st.success("✅ Données nettoyées avec succès !")
        st.balloons()
        st.markdown("---")

        # Nettoyage des compétences (enlève espaces inutiles)
        offres['competences'] = offres['competences'].astype(str).apply(lambda x: ','.join([c.strip() for c in x.split(',')]))
        cv_users['competences_cv'] = cv_users['competences_cv'].astype(str).apply(lambda x: ','.join([c.strip() for c in x.split(',')]))

        # TF-IDF
        vectorizer = TfidfVectorizer()
        X_cv = vectorizer.fit_transform(cv_users['competences_cv'])
        X_offres = vectorizer.transform(offres['competences'])

        # Similarité
        similarites = cosine_similarity(X_cv, X_offres)
        meilleures_offres_indices = np.argmax(similarites, axis=1)
        offres_recommandees = offres.iloc[meilleures_offres_indices]

        cv_users['offre_recommandee_titre'] = offres_recommandees['titre'].values
        cv_users['offre_recommandee_competences'] = offres_recommandees['competences'].values

        # KNN
        y = cv_users['offre_recommandee_titre']
        X_train, X_test, y_train, y_test = train_test_split(X_cv, y, test_size=0.2, random_state=42)

        y_encoder = LabelEncoder()
        y_train_enc = y_encoder.fit_transform(y_train)
        y_test_enc = y_encoder.transform(y_test)

        knn = KNeighborsClassifier(n_neighbors=5)
        knn.fit(X_train, y_train_enc)
        y_pred = knn.predict(X_test)
        acc = accuracy_score(y_test_enc, y_pred)

        st.info(f"🎯 Accuracy du modèle KNN : {acc:.2f}", icon="📊")
        st.markdown("---")

        # Générer les recommandations finales
        noms_personnes, titres_offres, competences_offres, localisations, types_contrat, salaires = [], [], [], [], [], []

        for i in range(len(cv_users)):
            nom = cv_users.iloc[i]['nom']
            cv_vect = X_cv[i]
            titre_pred_enc = knn.predict(cv_vect)[0]
            titre_pred = y_encoder.inverse_transform([titre_pred_enc])[0]
            offre_trouvee = offres[offres['titre'] == titre_pred].iloc[0]

            noms_personnes.append(nom)
            titres_offres.append(offre_trouvee['titre'])
            competences_offres.append(offre_trouvee['competences'])
            localisations.append(offre_trouvee['localisation'])
            types_contrat.append(offre_trouvee['type_contrat'])
            salaires.append(offre_trouvee['salaire'])

        # Créer la table finale
        table_recommandations = pd.DataFrame({
            'Nom': noms_personnes,
            'Titre Offre Recommandée': titres_offres,
            'Compétences Requises': competences_offres,
            'Localisation': localisations,
            'Type de Contrat': types_contrat,
            'Salaire': salaires
        })



        st.markdown("""
        <div style='background: #fff; border-radius: 14px; box-shadow: 0 2px 12px #1976d233; padding: 18px 18px 10px 18px; margin-bottom: 18px;'>
        <h3 style='color:#1976d2; margin-bottom: 18px;'>📋 Tableau final de recommandations</h3>
        </div>
        """, unsafe_allow_html=True)
        st.dataframe(table_recommandations, use_container_width=True, height=400)
        st.markdown("---")

        # Export
        st.download_button(
            label="💾 Télécharger les recommandations (CSV)",
            data=table_recommandations.to_csv(index=False).encode('utf-8'),
            file_name="recommandations_utilisateurs.csv",
            mime='text/csv',
            help="Cliquez pour exporter le tableau des recommandations."
        )

        # Footer élégant
        st.markdown("""
        <hr style='border:1px solid #e3f2fd;margin-top:40px;margin-bottom:10px;'>
        <div style='text-align:center; color:#1976d2; font-size:1.05em; margin-bottom:10px;'>
            © 2026 - Learnify | Réalisé avec <span style='color:#e53935;'>❤</span> par votre équipe Data
        </div>
        """, unsafe_allow_html=True)
