pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "job-service"
        DOCKER_TAG = "latest"
        SONAR_URL = "http://localhost:9000"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Unit Tests') {
            steps {
                dir('integrated/job-service') {
                    sh 'chmod +x mvnw'
                    sh './mvnw test -Dhttps.protocols=TLSv1.2'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('integrated/job-service') {
                    withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]) {
                        sh "./mvnw sonar:sonar -Dsonar.host.url=${SONAR_URL} -Dsonar.login=${SONAR_TOKEN} -Dhttps.protocols=TLSv1.2"
                    }
                }
            }
        }

        stage('Build Artifact') {
            steps {
                dir('integrated/job-service') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests -Dhttps.protocols=TLSv1.2'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('integrated/job-service') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }

        stage('Deploy') {
            steps {
                sh "docker stop ${DOCKER_IMAGE} || true"
                sh "docker rm ${DOCKER_IMAGE} || true"
                sh """
                    docker run -d --name ${DOCKER_IMAGE} \
                    -p 8088:8088 \
                    --link mysql-db:mysql-db \
                    --link eureka-server:eureka-server \
                    -e SPRING_DATASOURCE_URL='jdbc:mysql://mysql-db:3306/learnify_jobs?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true' \
                    -e SPRING_DATASOURCE_USERNAME='root' \
                    -e SPRING_DATASOURCE_PASSWORD='votre_mdp' \
                    -e EUREKA_SERVER_HOST='eureka-server' \
                    ${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }
}
