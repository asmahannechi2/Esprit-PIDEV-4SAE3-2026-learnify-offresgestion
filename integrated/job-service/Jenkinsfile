pipeline {
    agent any
    environment {
        DOCKER_IMAGE = "job-service"
        DOCKER_TAG = "latest"
        DOCKERHUB_USER = "asmahannachi2"
        SONAR_URL = "http://localhost:9000"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Unit Tests') {
            steps {
                dir('integrated/job-service') {
                    sh 'chmod +x mvnw'
                    sh './mvnw test -Dhttps.protocols=TLSv1.2'
                }
            }
        }
        stage('SonarQube Analysis') {
            when {
                expression { true }
            }
            steps {
                dir('integrated/job-service') {
                    withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]) {
                        sh "./mvnw sonar:sonar -Dsonar.host.url=${SONAR_URL} -Dsonar.token=${SONAR_TOKEN} -Dhttps.protocols=TLSv1.2"
                    }
                }
            }
        }
        stage('Build Artifact') {
            steps {
                dir('integrated/job-service') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests -Dhttps.protocols=TLSv1.2'
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                dir('integrated/job-service') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }
        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKERHUB_USER}/${DOCKER_IMAGE}:${DOCKER_TAG}
                        docker push ${DOCKERHUB_USER}/${DOCKER_IMAGE}:${DOCKER_TAG}
                    """
                }
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh "kubectl apply -f kubernetes/job-service.yaml"
                    sh "kubectl rollout status deployment/job-service --timeout=5m"
                    echo "✅ Job Service deployed successfully"
                }
            }
        }
    }
}
